# Copy to .env for local dev. In production, set these in Render dashboard.
ENV=dev
DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@localhost:5432/portfolio
# Neon production example (use the POOLED connection string for the app):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb
# Optional until the auth / rate-limiting sprint:
REDIS_URL=
# Comma-separated exact origins allowed to call the API with credentials:
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
